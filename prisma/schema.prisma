generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdChannel {
  META
  GOOGLE
  TIKTOK
  SHOPEE
}

enum ConversionSourceType {
  SHOPIFY
  CRM
  TYPEFORM
  API
  MANUAL
  OTHER
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// --- Empresas (Multi-tenancy) ---

model Company {
  id              String   @id @default(cuid())
  name            String
  segment         String   @default("other")
  logo            String?
  status          String   @default("active")
  responsibleName String?
  phone           String?
  whatsapp        String?
  city            String?
  state           String?
  website         String?
  instagram       String?
  facebook        String?
  tiktok          String?
  shopee          String?
  googleBusiness  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users                 CompanyUser[]
  leads                 Lead[]
  adAccounts            AdAccount[]
  campaigns             Campaign[]
  conversions           ConversionEvent[]
  whatsappConversations WhatsAppConversation[]
  sales                 Sale[]
  integrations          CompanyIntegration[]
  auditLogs             AuditLog[]
  knowledge             CompanyKnowledge?
  leadInteractions      LeadInteraction[]

  // MASTER 06: Revenue Engine
  revenueSales          RevenueSale[]
  revenueSources        RevenueSource[]
  revenueProducts       RevenueProduct[]
  revenueIndicators     RevenueIndicator[]
  revenueLossReasons    RevenueLossReason[]
  revenueTimelines      RevenueTimeline[]
  revenueGoals          RevenueGoal[]
  revenueForecasts      RevenueForecast[]
  revenueCommissions    RevenueCommission[]
  revenueScores         RevenueScore[]

  @@index([status])
  @@index([segment])
}

// --- Auth (NextAuth) ---

model User {
  id               String        @id @default(cuid())
  name             String?
  email            String        @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  defaultCompanyId String?
  accounts         Account[]
  sessions         Session[]
  companyUsers     CompanyUser[]
  auditLogs        AuditLog[]
  createdAt        DateTime      @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Permissões ---

model CompanyUser {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String   @default("analyst")
  isOwner   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions CompanyUserPermission[]
  auditLogs   AuditLog[]

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([role])
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  category    String

  companyUsers CompanyUserPermission[]
}

model CompanyUserPermission {
  id            String   @id @default(cuid())
  companyUserId String
  permissionId  String
  grantedAt     DateTime @default(now())

  companyUser CompanyUser @relation(fields: [companyUserId], references: [id], onDelete: Cascade)
  permission  Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([companyUserId, permissionId])
}

// --- Ad accounts / campaigns / metrics ---

model AdAccount {
  id                String    @id @default(cuid())
  channel           AdChannel
  externalAccountId String
  name              String
  loginCustomerId   String? // Google Ads MCC, quando aplicável
  accessToken       String?
  refreshToken      String?
  lastSyncedAt      DateTime?
  companyId         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  campaigns Campaign[]
  company   Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([channel, externalAccountId])
  @@index([companyId])
  @@index([channel, companyId])
}

model Campaign {
  id                 String    @id @default(cuid())
  adAccountId        String
  adAccount          AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  externalCampaignId String
  name               String
  objective          String?
  companyId          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  snapshots       MetricSnapshot[]
  conversions     ConversionEvent[] @relation("ConversionsToCampaign")
  alerts          Alert[]
  company         Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  leads           Lead[]
  sales           Sale[]
  revenueSales    RevenueSale[]     @relation("RevenueSalesToCampaign")

  @@unique([adAccountId, externalCampaignId])
  @@index([companyId])
}

model MetricSnapshot {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  spend           Decimal  @db.Decimal(12, 2)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  conversionValue Decimal? @db.Decimal(12, 2)
  raw             Json? // payload bruto da API pra auditoria/debug
  createdAt       DateTime @default(now())

  @@unique([campaignId, date])
}

// --- Conversões offline (de qualquer origem) ---

model ConversionEvent {
  id             String               @id @default(cuid())
  campaignId     String?
  campaign       Campaign?            @relation("ConversionsToCampaign", fields: [campaignId], references: [id], onDelete: SetNull)
  channel        AdChannel
  sourceType     ConversionSourceType
  amount         Decimal?             @db.Decimal(12, 2)
  externalId     String?
  metadata       Json?
  pushBackStatus String?
  pushBackError  String?
  companyId      String?
  utm_source     String?
  utm_medium     String?
  utm_campaign   String?
  utm_term       String?
  utm_content    String?
  device         String?
  browser        String?
  os             String?
  createdAt      DateTime             @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([channel])
  @@index([companyId])
  @@index([createdAt])
  @@index([companyId, createdAt])
  @@index([companyId, channel])
}

// --- Alertas ---

model Alert {
  id           String        @id @default(cuid())
  campaignId   String?
  campaign     Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  severity     AlertSeverity
  type         String // "cpa_spike", "ctr_drop", "no_conversions", etc
  message      String
  threshold    Decimal?      @db.Decimal(12, 4)
  currentValue Decimal?      @db.Decimal(12, 4)
  dismissedAt  DateTime?
  createdAt    DateTime      @default(now())

  @@index([campaignId])
  @@index([severity])
  @@index([createdAt])
}

// --- Leads (CRM) ---

model Lead {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  email           String?
  phone           String?
  whatsapp        String?
  source          String   @default("organic")
  campaign        String?
  adSet           String?
  ad              String?
  keyword         String?
  city            String?
  state           String?
  country         String?  @default("BR")
  productInterest String?
  estimatedValue  Decimal? @db.Decimal(12, 2)
  campaignId      String?
  valueInvested   Decimal? @db.Decimal(12, 2)
  notes_internal  String?
  tagsJson        String?
  customFields    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaignRef Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  revenueSales RevenueSale[]

  @@unique([companyId, email, phone])
  @@index([companyId])
  @@index([source])
  @@index([campaign])
  @@index([createdAt])
}

// --- Vendas (Financeiro) ---

model Sale {
  id            String    @id @default(cuid())
  companyId     String
  amount        Decimal   @db.Decimal(12, 2)
  profit        Decimal?  @db.Decimal(12, 2)
  commission    Decimal?  @db.Decimal(12, 2)
  source        String    @default("manual")
  campaignId    String?
  paymentMethod String?
  paymentStatus String    @default("pending")
  productName   String?
  quantity      Int?      @default(1)
  notes         String?
  customFields  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([source])
  @@index([paymentStatus])
  @@index([createdAt])
}

// --- Integrações ---

model CompanyIntegration {
  id            String    @id @default(cuid())
  companyId     String
  type          String
  name          String
  status        String    @default("disconnected")
  accessToken   String?   @db.Text
  refreshToken  String?   @db.Text
  webhookSecret String?
  config        Json?
  lastSyncAt    DateTime?
  lastErrorAt   DateTime?
  lastError     String?
  testedAt      DateTime?
  connectedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type])
  @@index([companyId])
  @@index([status])
}

// --- WhatsApp ---

model WhatsAppConversation {
  id                  String    @id @default(cuid())
  companyId           String
  phoneNumber         String
  status              String    @default("open")
  lastMessageAt       DateTime?
  averageResponseTime Int?
  notes               String?
  customFields        Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages WhatsAppMessage[]

  @@unique([companyId, phoneNumber])
  @@index([companyId])
  @@index([status])
}

model WhatsAppMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  externalId     String?
  type           String?
  mediaUrl       String?
  sentiment      String?
  hasObjection   Boolean?
  createdAt      DateTime @default(now())

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
}

// --- Auditoria ---

model AuditLog {
  id            String   @id @default(cuid())
  companyId     String
  userId        String?
  companyUserId String?
  action        String
  resource      String
  resourceId    String?
  changes       Json?
  description   String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyUser CompanyUser? @relation(fields: [companyUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

// --- IA Autônoma para Leads ---

model CompanyKnowledge {
  id                String    @id @default(cuid())
  companyId         String    @unique

  // Website
  websiteUrl        String?
  websiteContent    String?   @db.Text

  // Instagram
  instagramHandle   String?
  instagramBio      String?
  instagramPosts    Json?

  // Produtos/Serviços
  products          Json?
  services          Json?

  // Informações-chave
  mission           String?   @db.Text
  values            Json?
  history           String?   @db.Text
  locations         Json?

  // Horários e contato
  businessHours     Json?
  phone             String?
  email             String?

  // Embedding para busca
  knowledgeEmbedding String? @db.Text

  // Rastreamento
  lastScrapedAt     DateTime?
  scrapedFrom       String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model LeadInteraction {
  id                String    @id @default(cuid())
  companyId         String

  sourceType        String
  leadEmail         String?
  leadPhone         String?
  leadName          String?

  messageReceived   String    @db.Text
  aiResponse        String    @db.Text

  actionTaken       String
  qualificationScore Int?
  resultType        String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([sourceType])
  @@index([resultType])
  @@index([createdAt])
}

// ==================================================================================
// MASTER 06: REVENUE ENGINE - Inteligência de Receita
// ==================================================================================

enum RevenueSaleStatus {
  NOVO
  EM_ATENDIMENTO
  AGUARDANDO
  VENDA_REALIZADA
  VENDA_PERDIDA
  CANCELADO
  POS_VENDA
}

enum RevenueSourceType {
  META
  GOOGLE
  TIKTOK
  SHOPEE
  LINKEDIN
  PINTEREST
  ORGANIC
  DIRECT
  REFERRAL
  OTHER
}

enum RevenueLossReasonType {
  PRECO
  CONCORRENTE
  SEM_INTERESSE
  SEM_RETORNO
  SEM_ESTOQUE
  PRAZO
  OUTRO
}

// --- Revenue Sales: Vendas com histórico completo ---
model RevenueSale {
  id                String                @id @default(cuid())
  companyId         String
  leadId            String?
  campaignId        String?
  saleSourceId      String?

  status            RevenueSaleStatus     @default(NOVO)

  // Cliente
  clientName        String
  clientPhone       String?
  clientEmail       String?

  // Valor e Produtos
  totalAmount       Decimal               @db.Decimal(12, 2)
  products          Json // array de {id, name, quantity, unitPrice, totalPrice}

  // Atendimento
  attendantId       String? // userId que atendeu
  attendantName     String?

  // Pagamento
  paymentMethod     String?
  paymentStatus     String                @default("pending")
  paymentDate       DateTime?

  // Custos e Margem
  totalCost         Decimal?              @db.Decimal(12, 2) // custo dos produtos
  advertisingCost   Decimal?              @db.Decimal(12, 2) // custo do anúncio
  otherCosts        Decimal?              @db.Decimal(12, 2) // outros custos
  profitAmount      Decimal?              @db.Decimal(12, 2) // lucro bruto
  profitMargin      Decimal?              @db.Decimal(5, 2) // % margem

  // Se perdida
  lossReasonId      String?
  lossNotes         String?
  valueLost         Decimal?              @db.Decimal(12, 2)

  // Observações e Metadados
  notes             String?
  customFields      Json?

  saleDate          DateTime              @default(now())
  saleTime          String? // HH:MM formato
  completedAt       DateTime?
  canceledAt        DateTime?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead              Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  campaign          Campaign?             @relation("RevenueSalesToCampaign", fields: [campaignId], references: [id], onDelete: SetNull)
  source            RevenueSource?        @relation(fields: [saleSourceId], references: [id], onDelete: SetNull)
  lossReason        RevenueLossReason?    @relation(fields: [lossReasonId], references: [id], onDelete: SetNull)

  timeline          RevenueTimeline[]
  commissions       RevenueCommission[]

  @@index([companyId])
  @@index([status])
  @@index([saleSourceId])
  @@index([campaignId])
  @@index([paymentStatus])
  @@index([saleDate])
  @@index([companyId, saleDate])
  @@index([companyId, status])
}

// --- Revenue Source: Origem de vendas ---
model RevenueSource {
  id                String                @id @default(cuid())
  companyId         String

  sourceType        RevenueSourceType
  displayName       String
  description       String?
  isActive          Boolean               @default(true)

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales             RevenueSale[]

  @@unique([companyId, sourceType])
  @@index([companyId])
}

// --- Revenue Product: Produtos com margem ---
model RevenueProduct {
  id                String                @id @default(cuid())
  companyId         String

  name              String
  description       String?
  sku               String?
  category          String?

  basePrice         Decimal               @db.Decimal(12, 2)
  costPrice         Decimal?              @db.Decimal(12, 2)
  marginPercent     Decimal?              @db.Decimal(5, 2)

  commissionType    String?               // fixed, percentage
  commissionAmount  Decimal?              @db.Decimal(12, 2)

  isActive          Boolean               @default(true)

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isActive])
}

// --- Revenue Loss Reason: Motivos de perda ---
model RevenueLossReason {
  id                String                @id @default(cuid())
  companyId         String

  reason            RevenueLossReasonType
  description       String?
  displayOrder      Int                   @default(0)
  isActive          Boolean               @default(true)

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales             RevenueSale[]

  @@unique([companyId, reason])
  @@index([companyId])
}

// --- Revenue Timeline: Histórico completo de cada venda ---
model RevenueTimeline {
  id                String                @id @default(cuid())
  companyId         String
  saleId            String

  eventType         String // lead_created, first_contact, stage_changed, sale_completed, etc
  eventDescription  String

  previousValue     String?
  newValue          String?

  userId            String? // quem fez a ação
  userEmail         String?

  createdAt         DateTime              @default(now())

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale              RevenueSale           @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([saleId])
  @@index([eventType])
  @@index([createdAt])
}

// --- Revenue Indicator: KPIs calculados ---
model RevenueIndicator {
  id                String                @id @default(cuid())
  companyId         String

  period            String                // day, week, month, quarter, year
  date              DateTime              @db.Date

  // Investimento
  totalInvestment   Decimal               @db.Decimal(12, 2)

  // Vendas
  totalRevenue      Decimal               @db.Decimal(12, 2)
  totalSales        Int
  avgTicket         Decimal               @db.Decimal(12, 2)

  // Custos e Lucro
  totalCost         Decimal?              @db.Decimal(12, 2)
  totalProfit       Decimal?              @db.Decimal(12, 2)
  profitMargin      Decimal?              @db.Decimal(5, 2)

  // Conversão
  totalLeads        Int
  conversionRate    Decimal               @db.Decimal(5, 2) // %

  // KPIs
  roas              Decimal               @db.Decimal(10, 2)
  roi               Decimal               @db.Decimal(10, 2) // %
  cac               Decimal               @db.Decimal(12, 2)
  cpa               Decimal               @db.Decimal(12, 2)
  ltv               Decimal?              @db.Decimal(12, 2)

  // Segmentação
  channel           String?
  campaignId        String?
  productId         String?
  attendantId       String?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, period, date, channel, campaignId, productId, attendantId])
  @@index([companyId])
  @@index([date])
  @@index([companyId, date])
  @@index([channel])
  @@index([campaignId])
}

// --- Revenue Goal: Metas ---
model RevenueGoal {
  id                String                @id @default(cuid())
  companyId         String

  name              String
  description       String?

  metricType        String // revenue, sales, roas, roi, etc
  targetValue       Decimal               @db.Decimal(12, 2)
  currentValue      Decimal               @db.Decimal(12, 2) @default(0)

  progressPercent   Decimal               @db.Decimal(5, 2) @default(0)

  startDate         DateTime
  endDate           DateTime
  status            String                @default("active") // active, completed, missed

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([metricType])
}

// --- Revenue Forecast: Projeções ---
model RevenueForecast {
  id                String                @id @default(cuid())
  companyId         String

  forecastDate      DateTime              @db.Date
  projectedRevenue  Decimal               @db.Decimal(12, 2)
  projectedSales    Int
  projectedProfit   Decimal?              @db.Decimal(12, 2)

  confidence        Decimal               @db.Decimal(3, 0) // 0-100%
  notes             String?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([forecastDate])
}

// --- Revenue Commission: Comissões ---
model RevenueCommission {
  id                String                @id @default(cuid())
  companyId         String
  saleId            String

  attendantId       String?
  attendantName     String?

  commissionType    String // fixed, percentage
  commissionAmount  Decimal               @db.Decimal(12, 2)

  status            String                @default("pending") // pending, calculated, paid
  paidAt            DateTime?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale              RevenueSale           @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([saleId])
}

// --- Revenue Score: Score para ranking ---
model RevenueScore {
  id                String                @id @default(cuid())
  companyId         String

  scoreType         String // campaign, product, attendant, channel
  targetId          String // campaign.id, product.id, etc

  score             Decimal               @db.Decimal(5, 2) // 0-100

  // Métrica base
  baseMetric        String // revenue, profit, roas, roi, etc
  baseValue         Decimal               @db.Decimal(12, 2)

  rank              Int?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, scoreType, targetId])
  @@index([companyId])
  @@index([scoreType])
}
