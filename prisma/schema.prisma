generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdChannel {
  META
  GOOGLE
  TIKTOK
  SHOPEE
}

enum ConversionSourceType {
  SHOPIFY
  CRM
  TYPEFORM
  API
  MANUAL
  OTHER
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// --- Empresas (Multi-tenancy) ---

model Company {
  id              String   @id @default(cuid())
  name            String
  segment         String   @default("other")
  logo            String?
  status          String   @default("active")
  responsibleName String?
  phone           String?
  whatsapp        String?
  city            String?
  state           String?
  website         String?
  instagram       String?
  facebook        String?
  tiktok          String?
  shopee          String?
  googleBusiness  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users                 CompanyUser[]
  leads                 Lead[]
  adAccounts            AdAccount[]
  campaigns             Campaign[]
  conversions           ConversionEvent[]
  whatsappConversations WhatsAppConversation[]
  sales                 Sale[]
  integrations          CompanyIntegration[]
  auditLogs             AuditLog[]
  knowledge             CompanyKnowledge?
  leadInteractions      LeadInteraction[]

  @@index([status])
  @@index([segment])
}

// --- Auth (NextAuth) ---

model User {
  id               String        @id @default(cuid())
  name             String?
  email            String        @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  defaultCompanyId String?
  accounts         Account[]
  sessions         Session[]
  companyUsers     CompanyUser[]
  auditLogs        AuditLog[]
  createdAt        DateTime      @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Permissões ---

model CompanyUser {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String   @default("analyst")
  isOwner   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions CompanyUserPermission[]
  auditLogs   AuditLog[]

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([role])
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  category    String

  companyUsers CompanyUserPermission[]
}

model CompanyUserPermission {
  id            String   @id @default(cuid())
  companyUserId String
  permissionId  String
  grantedAt     DateTime @default(now())

  companyUser CompanyUser @relation(fields: [companyUserId], references: [id], onDelete: Cascade)
  permission  Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([companyUserId, permissionId])
}

// --- Ad accounts / campaigns / metrics ---

model AdAccount {
  id                String    @id @default(cuid())
  channel           AdChannel
  externalAccountId String
  name              String
  loginCustomerId   String? // Google Ads MCC, quando aplicável
  accessToken       String?
  refreshToken      String?
  lastSyncedAt      DateTime?
  companyId         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  campaigns Campaign[]
  company   Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([channel, externalAccountId])
  @@index([companyId])
  @@index([channel, companyId])
}

model Campaign {
  id                 String    @id @default(cuid())
  adAccountId        String
  adAccount          AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  externalCampaignId String
  name               String
  objective          String?
  companyId          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  snapshots   MetricSnapshot[]
  conversions ConversionEvent[] @relation("ConversionsToCampaign")
  alerts      Alert[]
  company     Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  leads       Lead[]
  sales       Sale[]

  @@unique([adAccountId, externalCampaignId])
  @@index([companyId])
}

model MetricSnapshot {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  spend           Decimal  @db.Decimal(12, 2)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  conversionValue Decimal? @db.Decimal(12, 2)
  raw             Json? // payload bruto da API pra auditoria/debug
  createdAt       DateTime @default(now())

  @@unique([campaignId, date])
}

// --- Conversões offline (de qualquer origem) ---

model ConversionEvent {
  id             String               @id @default(cuid())
  campaignId     String?
  campaign       Campaign?            @relation("ConversionsToCampaign", fields: [campaignId], references: [id], onDelete: SetNull)
  channel        AdChannel
  sourceType     ConversionSourceType
  amount         Decimal?             @db.Decimal(12, 2)
  externalId     String?
  metadata       Json?
  pushBackStatus String?
  pushBackError  String?
  companyId      String?
  utm_source     String?
  utm_medium     String?
  utm_campaign   String?
  utm_term       String?
  utm_content    String?
  device         String?
  browser        String?
  os             String?
  createdAt      DateTime             @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([channel])
  @@index([companyId])
  @@index([createdAt])
  @@index([companyId, createdAt])
  @@index([companyId, channel])
}

// --- Alertas ---

model Alert {
  id           String        @id @default(cuid())
  campaignId   String?
  campaign     Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  severity     AlertSeverity
  type         String // "cpa_spike", "ctr_drop", "no_conversions", etc
  message      String
  threshold    Decimal?      @db.Decimal(12, 4)
  currentValue Decimal?      @db.Decimal(12, 4)
  dismissedAt  DateTime?
  createdAt    DateTime      @default(now())

  @@index([campaignId])
  @@index([severity])
  @@index([createdAt])
}

// --- Leads (CRM) ---

model Lead {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  email           String?
  phone           String?
  whatsapp        String?
  source          String   @default("organic")
  campaign        String?
  adSet           String?
  ad              String?
  keyword         String?
  city            String?
  state           String?
  country         String?  @default("BR")
  productInterest String?
  estimatedValue  Decimal? @db.Decimal(12, 2)
  campaignId      String?
  valueInvested   Decimal? @db.Decimal(12, 2)
  notes_internal  String?
  tagsJson        String?
  customFields    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaignRef Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([companyId, email, phone])
  @@index([companyId])
  @@index([source])
  @@index([campaign])
  @@index([createdAt])
}

// --- Vendas (Financeiro) ---

model Sale {
  id            String    @id @default(cuid())
  companyId     String
  amount        Decimal   @db.Decimal(12, 2)
  profit        Decimal?  @db.Decimal(12, 2)
  commission    Decimal?  @db.Decimal(12, 2)
  source        String    @default("manual")
  campaignId    String?
  paymentMethod String?
  paymentStatus String    @default("pending")
  productName   String?
  quantity      Int?      @default(1)
  notes         String?
  customFields  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([source])
  @@index([paymentStatus])
  @@index([createdAt])
}

// --- Integrações ---

model CompanyIntegration {
  id            String    @id @default(cuid())
  companyId     String
  type          String
  name          String
  status        String    @default("disconnected")
  accessToken   String?   @db.Text
  refreshToken  String?   @db.Text
  webhookSecret String?
  config        Json?
  lastSyncAt    DateTime?
  lastErrorAt   DateTime?
  lastError     String?
  testedAt      DateTime?
  connectedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type])
  @@index([companyId])
  @@index([status])
}

// --- WhatsApp ---

model WhatsAppConversation {
  id                  String    @id @default(cuid())
  companyId           String
  phoneNumber         String
  status              String    @default("open")
  lastMessageAt       DateTime?
  averageResponseTime Int?
  notes               String?
  customFields        Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages WhatsAppMessage[]

  @@unique([companyId, phoneNumber])
  @@index([companyId])
  @@index([status])
}

model WhatsAppMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  externalId     String?
  type           String?
  mediaUrl       String?
  sentiment      String?
  hasObjection   Boolean?
  createdAt      DateTime @default(now())

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
}

// --- Auditoria ---

model AuditLog {
  id            String   @id @default(cuid())
  companyId     String
  userId        String?
  companyUserId String?
  action        String
  resource      String
  resourceId    String?
  changes       Json?
  description   String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyUser CompanyUser? @relation(fields: [companyUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

// --- IA Autônoma para Leads ---

model CompanyKnowledge {
  id                String    @id @default(cuid())
  companyId         String    @unique

  // Website
  websiteUrl        String?
  websiteContent    String?   @db.Text

  // Instagram
  instagramHandle   String?
  instagramBio      String?
  instagramPosts    Json?

  // Produtos/Serviços
  products          Json?
  services          Json?

  // Informações-chave
  mission           String?   @db.Text
  values            Json?
  history           String?   @db.Text
  locations         Json?

  // Horários e contato
  businessHours     Json?
  phone             String?
  email             String?

  // Embedding para busca
  knowledgeEmbedding String? @db.Text

  // Rastreamento
  lastScrapedAt     DateTime?
  scrapedFrom       String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model LeadInteraction {
  id                String    @id @default(cuid())
  companyId         String

  sourceType        String
  leadEmail         String?
  leadPhone         String?
  leadName          String?

  messageReceived   String    @db.Text
  aiResponse        String    @db.Text

  actionTaken       String
  qualificationScore Int?
  resultType        String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([sourceType])
  @@index([resultType])
  @@index([createdAt])
}
